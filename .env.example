POSTGRES_DB=learning_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

DATABASE_URL=postgresql+asyncpg://admin:password@postgres:5432/learning_db
SYNC_DATABASE_URL=postgresql://admin:password@postgres:5432/learning_db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-this-secret

# Local/demo mode only. Set to false before using real users.
DEMO_AUTH_BYPASS_ENABLED=true
DEMO_LOGIN_EMAILS=admin@example.com,student@example.com
DEMO_SIGNUP_EMAIL_DOMAIN=demo.local

# Email OTP sender settings are configured inside the app by an admin:
# User menu -> Settings -> Email sender.
